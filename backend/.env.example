# App Settings
APP_NAME="STRATOS Backend"
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# LLM Configuration
LLM_API_KEY="your_llm_api_key_here"
LLM_MODEL="gpt-4o-mini"

# FAA API Credentials
FAA_CLIENT_ID="your_faa_client_id_here"
FAA_CLIENT_SECRET="your_faa_client_secret_here"

# Laminar Data Hub API
LAMINAR_USER_KEY="your_laminar_user_key_here"

# SondeHub trajectory prediction
SONDEHUB_TAWHIRI_ENDPOINT="https://api.v2.sondehub.org/tawhiri"
