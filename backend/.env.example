# App Settings
APP_NAME="STRATOS Backend"
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# LLM Configuration
LLM_API_KEY="your_llm_api_key_here"
LLM_MODEL="gpt-5-mini"

# FAA API Credentials
FAA_CLIENT_ID="your_faa_client_id_here"
FAA_CLIENT_SECRET="your_faa_client_secret_here"

# ASTRA forecast cache
ASTRA_GFS_CACHE_DIR="./.cache/astra/gfs"
